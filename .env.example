# Copy this file to .env and fill only the providers you use.

# Optional provider selector. CLI --provider still takes precedence.
LENO_PROVIDER=deepseek

# Recommended default. DeepSeek uses its Anthropic-compatible endpoint.
LENO_DEEPSEEK_API_BASE=https://api.deepseek.com/anthropic
LENO_DEEPSEEK_API_KEY=
LENO_DEEPSEEK_MODEL=deepseek-v4-pro

# Optional right.codes shared key. Used by --provider openai and --provider anthropic when provider-specific keys are empty.
LENO_RIGHT_CODES_API_KEY=

# Default OpenAI-compatible endpoint. Change this if you use another /responses-compatible service.
LENO_OPENAI_API_BASE=https://www.right.codes/codex/v1
LENO_OPENAI_API_KEY=
LENO_OPENAI_MODEL=gpt-5.4

# Default Anthropic-compatible endpoint. Can reuse LENO_RIGHT_CODES_API_KEY when your gateway shares one key.
LENO_ANTHROPIC_API_BASE=https://www.right.codes/claude/v1
LENO_ANTHROPIC_API_KEY=
LENO_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional comma-separated extra env names to redact from traces and reports.
LENO_SECRET_ENV_NAMES=
